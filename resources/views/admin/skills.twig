{% extends 'layouts/base.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">{{ title }}</h1>
      <div>
        <a href="/admin/stats" class="btn btn-outline-secondary me-2">
          <i class="bi bi-bar-chart"></i> Dashboard
        </a>
        <a href="/admin/users" class="btn btn-outline-primary">
          <i class="bi bi-people"></i> Users
        </a>
      </div>
    </div>

    {% if success %}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ success }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}
    
    {% if error %}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ error }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title">Add New Skill</h5>
        <form method="POST" action="/admin/skills" class="row g-3">
          <div class="col-md-5">
            <input type="text" name="name" class="form-control" placeholder="Skill name" required>
          </div>
          <div class="col-md-5">
            <input type="text" name="category" class="form-control" placeholder="Category" required>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-plus-circle"></i> Add
            </button>
          </div>
        </form>
      </div>
    </div>

    {% for category, skills in skillsByCategory %}
    <div class="card mb-3">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="bi bi-folder"></i> {{ category }}
          <span class="badge bg-secondary">{{ skills|length }}</span>
        </h5>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for skill in skills %}
              <tr>
                <td>{{ skill.id }}</td>
                <td>
                  <span id="name-{{ skill.id }}">{{ skill.name }}</span>
                  <input type="text" id="edit-name-{{ skill.id }}" value="{{ skill.name }}" class="form-control form-control-sm d-none">
                </td>
                <td>
                  <span id="category-{{ skill.id }}">{{ skill.category }}</span>
                  <input type="text" id="edit-category-{{ skill.id }}" value="{{ skill.category }}" class="form-control form-control-sm d-none">
                </td>
                <td>
                  <button class="btn btn-sm btn-outline-primary" onclick="editSkill({{ skill.id }})">
                    <i class="bi bi-pencil"></i> Edit
                  </button>
                  <button class="btn btn-sm btn-success d-none" id="save-{{ skill.id }}" onclick="saveSkill({{ skill.id }})">
                    <i class="bi bi-check"></i> Save
                  </button>
                  <button class="btn btn-sm btn-secondary d-none" id="cancel-{{ skill.id }}" onclick="cancelEdit({{ skill.id }})">
                    Cancel
                  </button>
                  <form method="POST" action="/admin/skills/{{ skill.id }}/delete" class="d-inline" onsubmit="return confirm('Delete this skill?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>

<script>
function editSkill(id) {
  document.getElementById('name-' + id).classList.add('d-none');
  document.getElementById('category-' + id).classList.add('d-none');
  document.getElementById('edit-name-' + id).classList.remove('d-none');
  document.getElementById('edit-category-' + id).classList.remove('d-none');
  document.getElementById('save-' + id).classList.remove('d-none');
  document.getElementById('cancel-' + id).classList.remove('d-none');
  document.querySelector(`button[onclick="editSkill(${id})"]`).classList.add('d-none');
}

function cancelEdit(id) {
  document.getElementById('name-' + id).classList.remove('d-none');
  document.getElementById('category-' + id).classList.remove('d-none');
  document.getElementById('edit-name-' + id).classList.add('d-none');
  document.getElementById('edit-category-' + id).classList.add('d-none');
  document.getElementById('save-' + id).classList.add('d-none');
  document.getElementById('cancel-' + id).classList.add('d-none');
  document.querySelector(`button[onclick="editSkill(${id})"]`).classList.remove('d-none');
}

function saveSkill(id) {
  const name = document.getElementById('edit-name-' + id).value;
  const category = document.getElementById('edit-category-' + id).value;
  
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '/admin/skills/' + id;
  
  const nameInput = document.createElement('input');
  nameInput.type = 'hidden';
  nameInput.name = 'name';
  nameInput.value = name;
  
  const categoryInput = document.createElement('input');
  categoryInput.type = 'hidden';
  categoryInput.name = 'category';
  categoryInput.value = category;
  
  form.appendChild(nameInput);
  form.appendChild(categoryInput);
  document.body.appendChild(form);
  form.submit();
}
</script>
{% endblock %}
