{% extends 'layouts/base.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">{{ title }}</h1>
      <div>
        <a href="/admin/users" class="btn btn-outline-primary me-2">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/admin/skills" class="btn btn-outline-primary">
          <i class="bi bi-tools"></i> Skills
        </a>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6 col-xl-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <h6 class="text-muted mb-1">Total Users</h6>
                <h2 class="mb-0">{{ stats.total_users }}</h2>
              </div>
              <div class="text-primary">
                <i class="bi bi-people fs-1"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <h6 class="text-muted mb-1">Completed Profiles</h6>
                <h2 class="mb-0">{{ stats.users_with_skills }}</h2>
                <small class="text-muted">
                  {{ ((stats.users_with_skills / stats.total_users) * 100)|round }}% of users
                </small>
              </div>
              <div class="text-success">
                <i class="bi bi-check-circle fs-1"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <h6 class="text-muted mb-1">Active Sessions</h6>
                <h2 class="mb-0">{{ stats.active_sessions }}</h2>
                <small class="text-muted">Currently online</small>
              </div>
              <div class="text-info">
                <i class="bi bi-circle-fill fs-1"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-xl-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <h6 class="text-muted mb-1">Total Skills</h6>
                <h2 class="mb-0">{{ stats.total_skills }}</h2>
              </div>
              <div class="text-warning">
                <i class="bi bi-tools fs-1"></i>
              </div>
            </div>
          </div>
        </div>
      </div>

      {% if stats.total_events > 0 %}
      <div class="col-md-6 col-xl-3">
        <div class="card">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <h6 class="text-muted mb-1">Total Events</h6>
                <h2 class="mb-0">{{ stats.total_events }}</h2>
              </div>
              <div class="text-danger">
                <i class="bi bi-calendar-event fs-1"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endif %}
    </div>

    <div class="row mt-4">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Quick Actions</h5>
            <div class="d-flex gap-2 flex-wrap">
              <a href="/admin/users" class="btn btn-primary">
                <i class="bi bi-people"></i> Manage Users
              </a>
              <a href="/admin/skills" class="btn btn-primary">
                <i class="bi bi-tools"></i> Manage Skills
              </a>
              <a href="/events" class="btn btn-outline-secondary">
                <i class="bi bi-calendar-event"></i> View Events
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
