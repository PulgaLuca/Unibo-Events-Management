{% extends 'layouts/base.twig' %}

{% block title %}Crea un nuovo evento{% endblock %}

{% block content %}
    {# Hero Section con contrasto migliorato #}
    <header class="position-relative text-white overflow-hidden rounded-3 mb-4" style="background-color: #000;">
        <img src="/assets/images/events/event-main.jpg"
             id="main-event-image"
             alt="" 
             role="presentation"
             class="w-100 object-fit-cover" 
             style="height: 400px; filter: brightness(0.4);">
        
        <div class="position-absolute top-0 start-0 w-100 h-100 p-4 d-flex flex-column justify-content-center bg-dark bg-opacity-25">
            <h1 class="display-5 fw-bold">Crea un nuovo evento</h1>
            <p class="lead">Mettiti alla prova con la tua community e porta il tuo talento nel mondo.</p>
            <p class="mb-4 d-none d-md-block">Cerca eventi interni, workshop o competizioni esterne <br>e trova i partecipanti giusti.</p>
        </div>
    </header>

    <main class="container mb-5" id="main-content">
        
        {# Feedback Regioni Live: Fondamentale per WCAG AA #}
        <div id="alert-container" aria-live="assertive" aria-atomic="true">
            {% if error %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                    <strong>Errore:</strong> {{ error }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Chiudi avviso errore"></button>
                </div>
            {% endif %}

            {% if success %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
                    {{ success }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Chiudi avviso successo"></button>
                </div>
            {% endif %}
        </div>

        {# Inizio Form #}
        <form method="post" action="/events/create" enctype="multipart/form-data" id="event-form" novalidate>
            
            <section aria-labelledby="form-section-title">
                <h2 id="form-section-title" class="visually-hidden">Dettagli dell'evento</h2>
                
                {% include "eventForm.twig" with {
                    data: data|default({}),
                    eventTypes: eventTypes,
                    participationTypes: participationTypes,
                    currentUser: currentUser
                } %}
            </section>
            
            {# Pulsanti di azione: Ordine logico e colori a contrasto #}
            <div class="d-flex justify-content-end gap-3 mt-4 pb-5">
                <a href="/events" class="btn btn-outline-dark px-4 py-2 fw-bold">
                    Annulla <span class="visually-hidden">e torna alla lista eventi</span>
                </a>
                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">
                    Crea Evento
                </button>
            </div>
        </form>
    </main>
{% endblock %}