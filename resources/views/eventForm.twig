<style>
    /* Local styles for accessible fieldset */
    fieldset.card-fieldset {
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        background-color: #fff;
        padding: 0;
        margin-bottom: 1.5rem;
        box-shadow: -6px -6px 14px rgba(0, 0, 0, 0.1);
    }
    legend.card-legend {
        width: 100%;
        padding: 1rem;
        margin-bottom: 0;
        font-size: 1.25rem;
        font-weight: bold;
        color: #0d6efd;
        border-bottom: 1px solid #dee2e6;
        background-color: transparent;
    }
    .fieldset-body {
        padding: 1rem;
    }
</style>

{% set readonly = not isCreator %}
<fieldset class="card-fieldset">
    <legend class="card-legend">General Information</legend>
    <div class="fieldset-body">
        <div class="mb-3">
            <label for="title" class="form-label fw-bold">Event Title</label>
            <input type="text" class="form-control" id="title" name="title" 
                   placeholder="e.g., Hackathon - Image Recognition" required
                   value="{{ data.title|default('') }}" {% if readonly %}readonly{% endif %}>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label fw-bold">Description</label>
            <textarea class="form-control" id="description" name="description" rows="3" 
                      placeholder="Describe event..." {% if readonly %}readonly{% endif %}>{{ data.description|default('') }}</textarea>
        </div>
    </div>
</fieldset>

<div class="row">
    <div class="col-lg-6">
        <fieldset class="card-fieldset h-100">
            <legend class="card-legend">Date and Times</legend>
            <div class="fieldset-body">
                <div class="mb-3">
                    <label for="start_date" class="form-label fw-bold text-primary">Start date and time</label>
                    <input type="datetime-local" class="form-control" id="start_date" name="start_date" required
                           value="{{ data.startDate is defined ? data.startDate|date('Y-m-d\\TH:i') : data.start_date|default('') }}" {% if readonly %}readonly{% endif %}>
                </div>
                <div class="mb-3">
                    <label for="end_date" class="form-label fw-bold text-primary">End date and time</label>
                    <input type="datetime-local" class="form-control" id="end_date" name="end_date"
                           value="{{ data.endDate is defined and data.endDate ? data.endDate|date('Y-m-d\\TH:i') : data.end_date|default('') }}" {% if readonly %}readonly{% endif %}>
                </div>
                <div class="mb-3">
                    <label for="registration_deadline" class="form-label fw-bold text-primary">Registration Deadline</label>
                    <input type="datetime-local" class="form-control" id="registration_deadline" name="registration_deadline"
                           value="{{ data.registrationDeadline is defined and data.registrationDeadline ? data.registrationDeadline|date('Y-m-d\\TH:i') : data.registration_deadline|default('') }}" {% if readonly %}readonly{% endif %}>
                </div>
            </div>
        </fieldset>
    </div>

    <div class="col-lg-6">
        <fieldset class="card-fieldset h-100">
            <legend class="card-legend">Location and Modalities</legend>
            <div class="fieldset-body">
                <div class="row">
                    <div class="col-6 mb-3">
                        <label for="location_country" class="form-label fw-bold text-primary">Country</label>
                        <input type="text" class="form-control" id="location_country" name="location_country" 
                               placeholder="Italy" value="{{ data.location.country|default('') }}" {% if readonly %}readonly{% endif %}>
                    </div>
                    <div class="col-6 mb-3">
                        <label for="location_city" class="form-label fw-bold text-primary">City</label>
                        <input type="text" class="form-control" id="location_city" name="location_city" 
                               placeholder="Bologna" value="{{ data.location.city|default('') }}" {% if readonly %}readonly{% endif %}>
                    </div>
                </div>

                <div class="mb-3">
                    <div id="event-map" 
                            role="application" 
                            aria-label="Interactive map of the event location"
                            style="height: 250px; width: 100%; border-radius: 8px; border: 1px solid #dee2e6; background: #eee;">
                    </div>
                    <small class="text-secondary fst-italic ms-1" id="map-status" aria-live="polite">Loading map...</small>
                </div>
                
                <div class="mb-3">
                    <label for="location_description" class="form-label fw-bold text-primary">Description</label>
                    <input type="text" class="form-control" id="location_description" name="location_description" 
                            placeholder="e.g., Room 3, Campus / Online"
                            value="{{ data.location.description|default('') }}" {% if readonly %}readonly{% endif %}>
                </div>

                <div class="mb-3">
                    <label for="url" class="form-label fw-bold text-primary">External URL</label>
                    <input type="url" class="form-control" id="url" name="url" 
                           placeholder="https://..." 
                           value="{{ data.url|default('') }}" {% if readonly %}readonly{% endif %}>
                </div>
                <input type="hidden" name="location_id" value="{{ data.location.id|default('') }}">
            </div>
        </fieldset>
    </div>
</div>

<div class="row mt-3">
    <div class="col-lg-6">
        <fieldset class="card-fieldset h-100">
            <legend class="card-legend">Participation</legend>
            <div class="fieldset-body">
                <div class="mb-3">
                    <label for="min_participants" class="form-label fw-bold text-primary">Min participants</label>
                    <input type="number" class="form-control" id="min_participants" name="min_participants" min="0"
                           value="{{ data.minParticipants|default(0) }}" {% if readonly %}readonly{% endif %}>
                </div>
                <div class="mb-3">
                    <label for="max_participants" class="form-label fw-bold text-primary">Max participants</label>
                    <input type="number" class="form-control" id="max_participants" name="max_participants" min="0"
                           value="{{ data.maxParticipants|default(0) }}" {% if readonly %}readonly{% endif %}>
                </div>
                <div class="mb-3">
                    <label for="participation_type_id" class="form-label fw-bold text-primary">Participation Type</label>
                    <select class="form-select" id="participation_type_id" name="participation_type_id" aria-required="true" {% if readonly %}disabled{% endif %} required>
                        {% for p in participationTypes %}
                            <option value="{{ p.id }}"
                                    {% if data.participationTypeId is defined and data.participationTypeId == p.id %}selected{% endif %}>
                                {{ p.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </fieldset>
    </div>

    <div class="col-lg-6">
        <fieldset class="card-fieldset h-100">
            <legend class="card-legend">Event Type</legend>
            <div class="fieldset-body">
                <div class="mb-3">
                    <label for="type_id" class="form-label fw-bold text-primary">Type</label>
                    <select class="form-select" id="type_id" name="type_id" aria-required="true" {% if readonly %}disabled{% endif %} required>
                        {% for type in eventTypes %}
                            <option value="{{ type.id }}"
                                    {% if data.typeId is defined and data.typeId == type.id %}selected{% endif %}>
                                {{ type.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="mb-3">
                    <label for="status" class="form-label fw-bold text-primary">Status</label>
                    <select class="form-select" id="status" name="status" aria-required="true" {% if readonly %}disabled{% endif %} required>
                        {% for s in ['Draft','Active','Completed','Cancelled'] %}
                            <option value="{{ s }}"
                                    {% if data.status is defined and (data.status.value is defined ? data.status.value : data.status) == s %}selected{% endif %}>
                                {{ s }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="mb-3">
                    <label for="creator_user_id" class="form-label fw-bold text-primary">Event Organizer</label>
                    <select class="form-select" id="creator_user_id" aria-label="Event Organizer" disabled>
                        {% if organizer %}
                            <option selected>
                                {{ organizer.email }}
                            </option>
                        {% else %}
                            <option selected>
                                Unknown organizer
                            </option>
                        {% endif %}
                    </select>
                </div>
            </div>
        </fieldset>
    </div>
</div>

<fieldset class="card-fieldset mt-3">
    <legend class="card-legend">6. Required Skills</legend>
    <div class="fieldset-body">
        <div class="mb-3">
            <label for="skills" class="form-label fw-bold">List the required skills</label>
            <input type="text" class="form-control" id="skills" name="skills" 
                   placeholder="e.g., Cybersecurity, Web Development, CI/CD" 
                   value="{{ data.requiredSkillsAsString|default('') }}" 
                   aria-describedby="skillsHelp" 
                   {% if readonly %}readonly{% endif %}>
            <div id="skillsHelp" class="form-text">Separate skills with a comma (e.g., React, SQL, Figma).</div>
        </div>
    </div>
</fieldset>
