<div>
    <label>Title</label><br>
    <input type="text" name="title" required
           value="{{ data.title|default('') }}">
</div>

<div>
    <label>Description</label><br>
    <textarea name="description">{{ data.description|default('') }}</textarea>
</div>

<div>
    <label>Start date</label><br>
    <input type="datetime-local" name="start_date" required
           value="{{ data.startDate is defined
                ? data.startDate|date('Y-m-d\\TH:i')
                : data.start_date|default('') }}">
</div>

<div>
    <label>End date</label><br>
    <input type="datetime-local" name="end_date"
           value="{{ data.endDate is defined and data.endDate
                ? data.endDate|date('Y-m-d\\TH:i')
                : data.end_date|default('') }}">
</div>

<div>
    <label>Registration deadline</label><br>
    <input type="datetime-local" name="registration_deadline"
           value="{{ data.registrationDeadline is defined and data.registrationDeadline
                ? data.registrationDeadline|date('Y-m-d\\TH:i')
                : data.registration_deadline|default('') }}">
</div>

<div>
    <label>Status</label><br>
    <select name="status" required>
        {% for s in ['Draft','Active','Completed','Cancelled'] %}
            <option value="{{ s }}"
                {% if data.status is defined and data.status.value == s %}selected{% endif %}>
                {{ s }}
            </option>
        {% endfor %}
    </select>
</div>

<div>
    <label>Min participants</label><br>
    <input type="number" name="min_participants" min="0"
           value="{{ data.minParticipants|default(0) }}">
</div>

<div>
    <label>Max participants</label><br>
    <input type="number" name="max_participants" min="0"
           value="{{ data.maxParticipants|default(0) }}">
</div>

<div>
    <label>Location</label><br>
    <input type="text" name="location"
           value="{{ data.location|default('') }}">
</div>

<div>
    <label>URL</label><br>
    <input type="url" name="url"
           value="{{ data.url|default('') }}">
</div>

<div>
    <label>Event type</label><br>
    <select name="type_id" required>
        {% for type in eventTypes %}
            <option value="{{ type.id }}"
                {% if data.typeId is defined and data.typeId == type.id %}selected{% endif %}>
                {{ type.name }}
            </option>
        {% endfor %}
    </select>
</div>

<div>
    <label>Participation type</label><br>
    <select name="participation_type_id" required>
        {% for p in participationTypes %}
            <option value="{{ p.id }}"
                {% if data.participationTypeId is defined and data.participationTypeId == p.id %}selected{% endif %}>
                {{ p.name }}
            </option>
        {% endfor %}
    </select>
</div>

{% if currentUser %}
    <div>
        <label>Creator</label><br>
        <strong>
            {{ currentUser.name }}
        </strong>
    </div>
{% endif %}