{% extends 'layouts/base.twig' %}

{% block title %}Come Funziona - MatchSkills{% endblock %}

{% block content %}
    {# HERO SECTION #}
    <div class="position-relative text-white overflow-hidden rounded-3 mb-5" style="background-color: #000;">
        {# Immagine di sfondo astratta o scura #}
        <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" 
             style="background: linear-gradient(45deg, #0d6efd, #6610f2); filter: blur(50px);"></div>
        
        <div class="position-relative p-5 text-center">
            <h1 class="display-4 fw-bold mb-3">Scopri come funziona MatchSkills</h1>
            <p class="lead mx-auto" style="max-width: 700px;">
                MatchSkills è progettata per aiutarti a trovare le persone giuste, 
                collaborare in modo efficace e valorizzare le tue competenze all’interno dell’università.
            </p>
        </div>
    </div>

    <main class="container mb-5">
        
        <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-3">
            
            {# STEP 1: Profilo #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-lines-fill display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">1. Crea il tuo profilo</h5>
                        <p class="text-muted small mb-3">Il tuo profilo è il cuore di MatchSkills.</p>
                        <ul class="list-unstyled text-start small text-secondary">
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Competenze tecniche (linguaggi, tecnologie)</li>
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Soft skill (teamwork, leadership)</li>
                            <li class="mb-2"><i class="bi bi-check2 text-primary me-2"></i>Obiettivi e disponibilità</li>
                        </ul>
                        <div class="alert alert-light border mt-3 py-2 small">
                            <i class="bi bi-info-circle me-1"></i> Più è completo, migliori saranno i match!
                        </div>
                    </div>
                </div>
            </div>

            {# STEP 2: Matchmaking #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-magic display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">2. Matchmaking Intelligente</h5>
                        <p class="text-muted small mb-3">Il sistema ti suggerisce connessioni basate su skill e obiettivi.</p>
                        <ul class="list-unstyled text-start small text-secondary">
                            <li class="mb-2"><i class="bi bi-people text-info me-2"></i>Studenti con skill complementari</li>
                            <li class="mb-2"><i class="bi bi-search text-info me-2"></i>Gruppi studio compatibili</li>
                            <li class="mb-2"><i class="bi bi-lightbulb text-info me-2"></i>Partner per progetti</li>
                        </ul>
                        <p class="small text-muted mt-2">Ogni suggerimento include un <strong class="text-dark">Punteggio di Compatibilità</strong>.</p>
                    </div>
                </div>
            </div>

            {# STEP 3: Gruppi e Team #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-collection-fill display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">3. Unisciti a Gruppi</h5>
                        <p class="text-muted small mb-3">Crea o trova team per studio, progetti o hackathon.</p>
                        <ul class="list-unstyled text-start small text-secondary">
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-warning me-2"></i>Descrizione chiara e skill richieste</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-warning me-2"></i>Numero min/max partecipanti</li>
                            <li class="mb-2"><i class="bi bi-arrow-right-short text-warning me-2"></i>Stato (In ricerca, Completo)</li>
                        </ul>
                        <p class="small text-muted mt-2">Unisciti tramite invito o suggerimento automatico.</p>
                    </div>
                </div>
            </div>

            {# STEP 4: Eventi Interni #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-calendar2-event display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">4. Eventi Interni</h5>
                        <p class="text-muted small mb-3">Partecipa alle attività della community universitaria.</p>
                        <div class="d-flex flex-wrap gap-2 justify-content-center mb-3">
                            <span class="badge bg-light text-secondary border">Coding Challenge</span>
                            <span class="badge bg-light text-secondary border">Workshop</span>
                            <span class="badge bg-light text-secondary border">Mini Hackathon</span>
                        </div>
                        <p class="small text-muted">Filtra gli eventi per competenze, argomento e difficoltà.</p>
                    </div>
                </div>
            </div>

            {# STEP 5: Eventi Esterni #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-globe-americas display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">5. Competizioni Esterne</h5>
                        <p class="text-muted small mb-3">Porta le tue competenze oltre l’università.</p>
                        <ul class="list-unstyled text-start small text-secondary">
                            <li class="mb-2"><i class="bi bi-trophy text-success me-2"></i>Esplora gare nazionali/internazionali</li>
                            <li class="mb-2"><i class="bi bi-flag text-success me-2"></i>Dichiara l'intenzione di partecipare</li>
                            <li class="mb-2"><i class="bi bi-person-plus text-success me-2"></i>Trova membri per il tuo team</li>
                        </ul>
                    </div>
                </div>
            </div>

            {# STEP 6: Crescita #}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-indigo bg-opacity-10 text-indigo rounded-circle mb-3" style="width: 80px; height: 80px; color: #6610f2;">
                            <i class="bi bi-graph-up-arrow display-5"></i>
                        </div>
                        <h5 class="fw-bold mb-3">6. Collabora e Cresci</h5>
                        <p class="text-muted small mb-3">Trasforma lo studio in collaborazione attiva.</p>
                        <ul class="list-unstyled text-start small text-secondary">
                            <li class="mb-2"><i class="bi bi-star text-dark me-2"></i>Collabora con studenti affini</li>
                            <li class="mb-2"><i class="bi bi-star text-dark me-2"></i>Sviluppa competenze pratiche</li>
                            <li class="mb-2"><i class="bi bi-star text-dark me-2"></i>Costruisci esperienze reali</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold">Esplora la Mappa degli Eventi</h2>
                            <p class="text-muted">Guarda cosa succede intorno a te e trova opportunità vicine.</p>
                        </div>
                        
                        {# Contenitore della mappa #}
                        <div id="eventsMap"></div>
                        
                    </div>
                </div>
            </div>
        </div>

        {# CALL TO ACTION #}
        <div class="row mt-5">
            <div class="col-12">
                <div class="bg-light rounded-4 p-5 text-center border">
                    <h2 class="fw-bold mb-3">Inizia ora la tua esperienza</h2>
                    <p class="lead text-muted mb-4">Entra nella community, completa il tuo profilo e scopri nuove opportunità di crescita.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/register" class="btn btn-primary btn-lg px-5 rounded-pill fw-bold">
                            Crea Profilo
                        </a>
                        <a href="/events" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
                            Esplora Eventi
                        </a>
                    </div>
                    <p class="small text-muted mt-4 mb-0">MatchSkills – Dalle competenze alle connessioni.</p>
                </div>
            </div>
        </div>

    </main>
{% endblock %}
