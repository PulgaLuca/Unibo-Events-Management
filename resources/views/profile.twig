{% extends 'layouts/base.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/assets/css/profile.css">
{% endblock %}

{% block scripts %}
<script src="/assets/js/profile.js"></script>
{% endblock %}

{% block content %}
<div class="row">
  <div class="col-12">
    <h1 class="h3 mb-4">{{ title }}</h1>
    
    {% if success %}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        Skills updated successfully!
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endif %}
    
    {% if error %}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        Error: {{ error }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endif %}

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title">User Information</h5>
        <p class="mb-1"><strong>Name:</strong> {{ user.first_name }} {{ user.last_name }}</p>
        <p class="mb-1"><strong>Email:</strong> {{ user.email }}</p>
        <p class="mb-0"><strong>Role:</strong> {{ user.role|capitalize }}</p>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h5 class="card-title mb-3">Manage Your Skills</h5>
        <p class="text-muted mb-4">
          Select the skills you have and rate your proficiency level from 1 (Beginner) to 4 (Expert).
          Click on a skill to select it, then choose your level.
        </p>

        <form method="POST" action="/profile" id="skillsForm">
          {% for category, skills in skillsByCategory %}
          <div class="category-section">
            <h6 class="text-primary mb-3">
              <i class="bi bi-folder"></i> {{ category }}
            </h6>
            <div class="skill-grid">
              {% for skill in skills %}
              <div class="skill-card card {% if userSkillsMap[skill.id] %}selected{% endif %}" data-skill-id="{{ skill.id }}">
                <div class="card-body p-3">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <label class="form-check-label mb-0" style="cursor: pointer; flex-grow: 1;">
                      {{ skill.name }}
                    </label>
                    {% if userSkillsMap[skill.id] %}
                    <span class="level-badge badge bg-primary">
                      Level {{ userSkillsMap[skill.id] }}
                    </span>
                    {% endif %}
                  </div>
                  
                  <div class="skill-level-selector mt-2">
                    <label class="form-label small mb-1">Proficiency Level:</label>
                    <select name="skills[{{ skill.id }}]" class="form-select form-select-sm skill-level" data-skill-id="{{ skill.id }}">
                      <option value="0">Not selected</option>
                      <option value="1" {% if userSkillsMap[skill.id] == 1 %}selected{% endif %}>1 - Beginner</option>
                      <option value="2" {% if userSkillsMap[skill.id] == 2 %}selected{% endif %}>2 - Intermediate</option>
                      <option value="3" {% if userSkillsMap[skill.id] == 3 %}selected{% endif %}>3 - Advanced</option>
                      <option value="4" {% if userSkillsMap[skill.id] == 4 %}selected{% endif %}>4 - Expert</option>
                    </select>
                  </div>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endfor %}

          <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
            <div class="text-muted">
              <small>
                <i class="bi bi-info-circle"></i>
                Total skills selected: <span id="skillCount">{{ userSkills|length }}</span>
              </small>
            </div>
            <div>
              <button type="button" id="resetSkills" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-counterclockwise"></i> Reset All
              </button>
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Save Skills
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
