{% extends 'layouts/base.twig' %}

{% block title %}Edit Team - {{ team.name }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="mb-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/teams">Teams</a></li>
                    <li class="breadcrumb-item"><a href="/teams/{{ team.id }}">{{ team.name }}</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </nav>
        </div>

        {% if error %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-octagon-fill me-2"></i>
                <strong>Error:</strong> {{ error }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h1 class="h4 mb-0">
                    <i class="bi bi-pencil me-2"></i>Edit Team: {{ team.name }}
                </h1>
            </div>
            <div class="card-body">
                <form method="post" action="/teams/{{ team.id }}/update">
                    <div class="mb-4">
                        <label for="name" class="form-label fw-bold">
                            Team Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" 
                               class="form-control" 
                               id="name" 
                               name="name" 
                               value="{{ team.name }}"
                               required 
                               placeholder="Enter team name"
                               maxlength="255">
                        <div class="form-text">Choose a meaningful and unique name for your team.</div>
                    </div>

                    <div class="mb-4">
                        <label for="description" class="form-label fw-bold">Description</label>
                        <textarea class="form-control" 
                                  id="description" 
                                  name="description" 
                                  rows="4" 
                                  placeholder="Describe your team's goals, values, or mission (optional)">{{ team.description }}</textarea>
                        <div class="form-text">Help others understand what your team is about.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label for="min_participants" class="form-label fw-bold">
                                Minimum Members <span class="text-danger">*</span>
                            </label>
                            <input type="number" 
                                   class="form-control" 
                                   id="min_participants" 
                                   name="min_participants" 
                                   value="{{ team.min_participants }}" 
                                   min="1" 
                                   max="100"
                                   required>
                            <div class="form-text">Minimum number of members required.</div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label for="max_participants" class="form-label fw-bold">
                                Maximum Members <span class="text-danger">*</span>
                            </label>
                            <input type="number" 
                                   class="form-control" 
                                   id="max_participants" 
                                   name="max_participants" 
                                   value="{{ team.max_participants }}" 
                                   min="1" 
                                   max="100"
                                   required>
                            <div class="form-text">Maximum number of members allowed.</div>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong> You cannot set the maximum members below the current member count.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                        <a href="/teams/{{ team.id }}" class="btn btn-outline-secondary btn-lg">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
    // Validate that max is greater than or equal to min
    document.querySelector('form').addEventListener('submit', function(e) {
        const min = parseInt(document.getElementById('min_participants').value);
        const max = parseInt(document.getElementById('max_participants').value);
        
        if (max < min) {
            e.preventDefault();
            alert('Maximum members must be greater than or equal to minimum members.');
        }
    });
</script>
{% endblock %}
