{% extends 'layouts/base.twig' %}

{% block title %}My Teams{% endblock %}

{% block content %}
<main class="container mt-4" role="main" aria-labelledby="page-title">

    <header class="d-flex justify-content-between align-items-center mb-4">
        <h1 id="page-title">My Teams</h1>

        <a
            href="/teams/create"
            class="btn btn-primary"
            role="button"
            aria-label="Create a new team"
        >
            Create Team
        </a>
    </header>

    {% if teams is empty %}
        <p role="status" aria-live="polite" class="alert alert-info">
            You are not part of any team yet.
        </p>
    {% else %}
        <section aria-labelledby="teams-list-title">
            <h2 id="teams-list-title" class="visually-hidden">
                List of your teams
            </h2>

            <ul class="row list-unstyled">
                {% for team in teams %}
                    <li class="col-md-4 mb-3">
                        {% include '_team_card.twig' with { team: team } %}
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

</main>
{% endblock %}
