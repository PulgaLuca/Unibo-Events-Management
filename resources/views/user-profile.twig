{% extends 'layouts/base.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/assets/css/profile.css">
<style>
  .skill-badge-display {
    display: inline-block;
    margin: 0.25rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    background-color: #f8f9fa;
    border: 1px solid #dee2e6;
  }
  .skill-badge-display .skill-name {
    font-weight: 500;
    color: var(--color-text);
  }
  .skill-badge-display .skill-level {
    margin-left: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-primary);
  }
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: #6c757d;
  }
  .empty-state i {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }
</style>
{% endblock %}

{% block content %}
<div class="row">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">{{ title }}</h1>
      <a href="javascript:history.back()" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title">User Information</h5>
        <p class="mb-1"><strong>Name:</strong> {{ viewedUser.first_name }} {{ viewedUser.last_name }}</p>
        <p class="mb-1"><strong>Email:</strong> {{ viewedUser.email }}</p>
        <p class="mb-0"><strong>Role:</strong> {{ viewedUser.role|capitalize }}</p>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h5 class="card-title mb-3">
          <i class="bi bi-tools"></i> Skills & Expertise
        </h5>
        
        {% if userSkills|length > 0 %}
          {% for category, skills in skillsByCategory %}
          <div class="mb-4">
            <h6 class="text-primary mb-3">
              <i class="bi bi-folder"></i> {{ category }}
            </h6>
            <div>
              {% for skill in skills %}
              <div class="skill-badge-display">
                <span class="skill-name">{{ skill.skill_name }}</span>
                <span class="skill-level">
                  {% if skill.level == 1 %}
                    <i class="bi bi-circle-fill"></i> Beginner
                  {% elseif skill.level == 2 %}
                    <i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i> Intermediate
                  {% elseif skill.level == 3 %}
                    <i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i> Advanced
                  {% elseif skill.level == 4 %}
                    <i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i><i class="bi bi-circle-fill"></i> Expert
                  {% endif %}
                </span>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
          
          <div class="mt-4 pt-3 border-top">
            <p class="text-muted mb-0">
              <i class="bi bi-info-circle"></i>
              <small>Total skills: <strong>{{ userSkills|length }}</strong></small>
            </p>
          </div>
        {% else %}
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p class="mb-0">This user hasn't added any skills yet.</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
